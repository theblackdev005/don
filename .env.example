APP_NAME=Around
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# Identité et coordonnées (voir config/site.php)
SITE_NAME=
SITE_TAGLINE=
SITE_LABEL_MEMBER_AREA=
SITE_LABEL_DASHBOARD=
SITE_META_DESCRIPTION=
SITE_META_KEYWORDS=
SITE_AUTHOR=
SITE_EMAIL=contact@example.com
SITE_PHONE=
SITE_PHONE_DISPLAY=
SITE_WHATSAPP=
SITE_MAP_URL=
# Adresse du siège (une ligne, ex. PDF) — prioritaire sur l’ancien découpage ci-dessous
SITE_ADDRESS=
SITE_ADDRESS_LINE1=
SITE_ADDRESS_LINE2=
SITE_ADDRESS_POSTAL=
SITE_ADDRESS_CITY=
SITE_ADDRESS_COUNTRY=

# Slugs d’URL (segments publics, sans / — voir config/site.php)
# SITE_SLUG_ABOUT=a-propos
# SITE_SLUG_SERVICES=services
# SITE_SLUG_CONTACT=contact
# SITE_SLUG_ACCOUNT=compte
# SITE_SLUG_FUNDING_REQUEST=demande-financement
# SITE_SLUG_FUNDING_CONFIRMATION=confirmation
# SITE_SLUG_DOSSIER_TRACKING=suivi-dossier

# Administration — compte créé par : php artisan db:seed --class=AdminUserSeeder
# Connexion : /admin/connexion (e-mail + mot de passe)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_SEED_NAME=Administrateur
ADMIN_NOTIFICATION_EMAIL=
# Acte de donation (PDF) — préféré :
DONATION_ACT_DIRECTOR_NAME="Nom du directeur"
DONATION_ACT_DIRECTOR_TITLE="Directeur du financement"
# Chemins relatifs au dossier public/
DONATION_ACT_LOGO_PATH=
DONATION_ACT_DIRECTOR_SIGNATURE_PATH=
# Anciennes variables (encore lues si les DONATION_ACT_* sont vides) :
# CONTRACT_DIRECTOR_NAME= CONTRACT_DIRECTOR_TITLE= CONTRACT_LOGO_PATH= CONTRACT_DIRECTOR_SIGNATURE_PATH=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=
MIGRATIONS_TABLE=migrations

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Brevo (recommandé en prod) : https://app.brevo.com/settings/keys/smtp
# Créer une « Clé SMTP » ; copier login (souvent l’e-mail du compte) + la clé.
# MAIL_FROM_ADDRESS = expéditeur vérifié dans Brevo (Senders / domaine authentifié).
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=votre-login-smtp@example.com
# MAIL_PASSWORD=votre-cle-smtp-brevo
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="no-reply@votredomaine.com"
# MAIL_FROM_NAME="${APP_NAME}"

# Mailtrap (tests) : https://mailtrap.io — Inbox > Integration
# Alternative locale : MAIL_HOST=mailpit MAIL_PORT=1025 (sans auth)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
